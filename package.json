{
  "name": "idpay-portal-merchants-frontend",
  "version": "1.0.0",
  "homepage": "portale-esercenti",
  "private": true,
  "dependencies": {
    "@emotion/cache": "11.13.5",
    "@emotion/react": "11.14.0",
    "@emotion/serialize": "1.3.3",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "5.18.0",
    "@mui/lab": "5.0.0-alpha.176",
    "@mui/material": "7.3.8",
    "@mui/system": "5.15.14",
    "@mui/utils": "5.17.1",
    "@mui/x-data-grid": "5.17.0",
    "@pagopa/mui-italia": "2.3.0",
    "@pagopa/selfcare-common-frontend": "1.34.92",
    "@reduxjs/toolkit": "2.11.2",
    "@types/dompurify": "^3.2.0",
    "@types/react": "18",
    "@types/react-redux": "7.1.34",
    "@types/redux-logger": "3.0.13",
    "date-fns": "^2.28.0",
    "dayjs": "^1.11.19",
    "dompurify": "3.3.2",
    "eslint-plugin-sonarjs": "^0.14.0",
    "formik": "^2.2.9",
    "i18next": "^26.0.1",
    "jest-sonar-reporter": "^2.0.0",
    "node-fetch": "^3.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "15.7.4",
    "react-redux": "7.2.9",
    "react-router-dom": "5.3.4",
    "react-scripts": "5.0.0",
    "redux": "5.0.1",
    "redux-thunk": "3.1.0",
    "reselect": "5.1.0",
    "url": "^0.11.0",
    "yup": "^0.32.11"
  },
  "scripts": {
    "clean": "npm-run-all clean:*",
    "clean:build": "rimraf build",
    "clean:coverage": "rimraf coverage",
    "clean:generated": "rimraf src/api/generated",
    "start": "craco start",
    "build": "craco build",
    "test": "craco test --testPathIgnorePatterns=src/utils/__tests__/test-utils.tsx -i",
    "test:coverage": "craco test --watchAll=false --testPathIgnorePatterns=src/utils/__tests__/test-utils.tsx -i --coverage --ci --testResultsProcessor jest-sonar-reporter",
    "lint": "eslint -f json -o eslint-report.json . -c .eslintrc.js --ext .ts,.tsx --cache",
    "lint-autofix": "eslint . -c .eslintrc.js --ext .ts,.tsx --fix",
    "prettify": "prettier --write \"./**/*.{ts,tsx}\"",

    "generate": "npm-run-all generate:api:*",

    "clean:api:merchants": "rimraf src/api/generated/merchants",
    "clean:api:email-notification": "rimraf src/api/generated/email-notification",
    "clean:api:autocomplete": "rimraf src/api/generated/autocomplete",
    "clean:api:role-permission": "rimraf src/api/generated/role-permission",

"generate:api:merchants": "npm-run-all clean:api:merchants && swagger-typescript-api generate --path openApi/openapi.merchants.portal.yml --output src/api/generated/merchants --name Api.ts --modular",
"generate:api:email-notification": "npm-run-all clean:api:email-notification && swagger-typescript-api generate --path openApi/openapi.email-notification.yml --output src/api/generated/email-notification --name Api.ts --modular",
"generate:api:autocomplete": "npm-run-all clean:api:autocomplete && swagger-typescript-api generate --path openApi/openapi.autocomplete.yml --output src/api/generated/autocomplete --name Api.ts --modular",
"generate:api:role-permission": "npm-run-all clean:api:role-permission && swagger-typescript-api generate --path openApi/openapi.role-permission.yml --output src/api/generated/role-permission --name Api.ts --modular"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@craco/craco": "^6.4.3",
    "@pagopa/openapi-codegen-ts": "^10.0.6",
    "@testing-library/jest-dom": "^5.16.3",
    "@testing-library/react": "12.1.2",
    "@testing-library/react-hooks": "7",
    "@testing-library/user-event": "^14.0.4",
    "@types/react-router-dom": "^5.3.3",
    "craco-module-federation": "^1.1.0",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-functional": "^4.2.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-react": "^7.26.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "js-yaml": "^4.1.1",
    "mkdirp": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^2.7.1",
    "process": "^0.11.10",
    "regex-replace": "^2.3.1",
    "rimraf": "^3.0.2",
    "swagger-typescript-api": "^13.6.7",
    "typescript": "5.1.6"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "@types/react": "18",
    "react-redux": "7.2.9",
    "@reduxjs/toolkit": "2.11.2",
    "redux": "5.0.1",
    "static-eval": "^2.0.2",
    "yargs": "^17.5.1",
    "jsonpath": "^1.1.1",
    "svgo": "^2.8.0",
    "json-schema-ref-parser": "^7.1.0",
    "z-schema": "^4.2.4"
  },
  "jest": {
    "restoreMocks": true,
    "clearMocks": true,
    "resetMocks": true,
    "transformIgnorePatterns": [
      "node_modules/(?!(@pagopa|@standard-schema|@mui)/)"
    ],
    "moduleNameMapper": {
      "next/router": "<rootDir>/__mocks__/next/router.js",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy",
      "^.+\\.(jpg|jpeg|png|gif|webp|avif|svg)$": "<rootDir>/__mocks__/file-mock.js",
      "react-markdown": "<rootDir>/node_modules/react-markdown/react-markdown.min.js"
    }
  }
}
